---
import {
  Facebook,
  Instagram,
  Linkedin,
  Phone,
  Mail,
  MapPin,
  ArrowRight
} from "lucide-react";

const footerBg = "/images/footerimage.png";
const footerMobileBg = "/images/footerMobileBg.png";
---

<footer class="relative w-full text-white">

<div class="absolute inset-0 bg-cover block lg:hidden" style={`background-image:url(${footerMobileBg})`}></div>
<div class="absolute inset-0 bg-cover bg-center hidden lg:block" style={`background-image:url(${footerBg})`}></div>

<div class="relative max-w-[1440px] mx-auto w-[90%] pt-[90px] pb-[50px]">

<!-- TOP -->
<div class="flex flex-col lg:flex-row justify-between gap-12">

<div class="space-y-12">

<div class="flex flex-wrap lg:flex-nowrap gap-6">

<a href="/">
  <img src="/images/marcamore-logo.svg" class="w-[212px] h-[48px]" />
</a>

<div class="relative">
  <a href="/insights">
    <img src="/images/marcamore-logo.svg" class="w-[140px] h-[32px]" />
    <img src="/images/insight-logo.svg" class="w-[122px] h-[68px] absolute -bottom-8 left-1/2 -translate-x-1/2" />
  </a>
</div>

</div>

<p class="text-[17px] font-medium leading-relaxed">
We are Marcamor, a media company and an award-winning <br />
marketing and web design agency.
</p>

</div>

</div>

<!-- SOCIAL -->
<div class="w-full flex flex-col lg:flex-row lg:items-center lg:justify-between flex-wrap mt-10">

<div>
<p class="text-[17px] mb-4 font-semibold">Follow Us:</p>

<div class="flex gap-4">

<a href="https://www.facebook.com/MarcamorMarketing" target="_blank" class="w-10 h-10 rounded-full border border-[#8a8381] hover:text-[#665f5d] flex items-center justify-center">
<Facebook size={20} />
</a>

<a href="https://www.instagram.com/marcamor_consulting?igsh=MXZqeGJmOHVyY3J1aA==" target="_blank" class="w-10 h-10 rounded-full border border-[#8a8381] hover:text-[#665f5d] flex items-center justify-center">
<Instagram size={20} />
</a>

<a href="https://www.linkedin.com/company/47661160/admin/dashboard/" target="_blank" class="w-10 h-10 rounded-full border border-[#8a8381] hover:text-[#665f5d] flex items-center justify-center">
<Linkedin size={20} />
</a>

</div>
</div>

<!-- LOCATIONS -->
<div class="flex flex-wrap items-center gap-10 mt-4">

<a href="https://maps.google.com?q=Hyderabad" target="_blank" class="flex items-center gap-3">
<img src="/icons/india.svg" class="w-[38px]" />
<div>
<p class="font-semibold text-[14px]">India</p>
<p class="text-[13px]">Hyderabad, Telangana 500081.</p>
</div>
</a>

<a href="https://maps.google.com?q=San+Francisco" target="_blank" class="flex items-center gap-3">
<img src="/icons/usa.svg" class="w-[38px]" />
<div>
<p class="font-semibold text-[14px]">United States</p>
<p class="text-[13px]">San Francisco, California 94108.</p>
</div>
</a>

<a href="https://maps.google.com?q=London" target="_blank" class="flex items-center gap-3">
<img src="/icons/uk.svg" class="w-[38px]" />
<div>
<p class="font-semibold text-[14px]">United Kingdom</p>
<p class="text-[13px]">Harrow, Greater London HA1 2LW.</p>
</div>
</a>

</div>

</div>

<div class="border-t border-[#FFFFFF33] my-14"></div>

<!-- LINKS -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-6">

<!-- QUICK -->
<div>
<h4 class="font-semibold text-[18px] mb-6 underline">Quick Links</h4>
<ul class="space-y-4 text-[16px]">
<li><a href="/">Home</a></li>
<li><a href="/work">Our Work</a></li>
<li><a href="/about">About</a></li>
<li><a href="/contact">Contact Us</a></li>
</ul>
</div>

<!-- SERVICES -->
<div>
<h4 class="font-semibold text-[18px] mb-6 underline">Services</h4>
<ul class="space-y-4 text-[16px]">

<li><a href="/services/digital-marketing">Digital Marketing</a></li>
<li><a href="/services/branding-design/branding-design">Branding and Design</a></li>
<li><a href="/services/business-consulting/business-consulting">Business Consulting</a></li>
<li><a href="/services/web-app-development/web-app-development">Website & App Development</a></li>
<li><a href="/services/technology-product-development">Technology & Product Development</a></li>
<li><a href="/services/performance-analytics">Performance & Analytics</a></li>
<li><a href="/services/market-research">Market Research Consumer</a></li>

</ul>
</div>

<!-- COMPANY -->
<div>
<h4 class="font-semibold text-[18px] mb-6 underline">Company</h4>
<ul class="space-y-4 text-[16px]">
<li><a href="/insights">Insights</a></li>
<li><a href="/careers">Career</a></li>
<li><a href="/faqs">FAQ</a></li>
<li><a href="/clients">Our Clients</a></li>
<li><a href="/franchising">Franchising</a></li>
</ul>
</div>

<!-- CONTACT -->
<div>
<h4 class="font-semibold text-[18px] mb-6 underline">Contacts</h4>

<div class="space-y-4 text-[16px]">

<div class="flex gap-3 items-start">
<Phone size={16}/>
<a href="tel:+919985202223">+91 99852 02223</a>
</div>

<div class="flex gap-3 items-start">
<Mail size={16}/>
<a href="mailto:info@marcamor.com">info@marcamor.com</a>
</div>

<div class="flex gap-3 items-start">
<MapPin size={20}/>
<span>Hyderabad, Telangana 500081</span>
</div>

<a href="https://maps.google.com?q=Hyderabad" target="_blank" class="flex items-center gap-2 text-[#EE5125] uppercase text-[13px]">
Get Direction
<ArrowRight size={14}/>
</a>

</div>

</div>

</div>
<div class="border-t border-white/10 my-14"></div> <div class="flex flex-wrap justify-center gap-8 text-white/50 text-[12px] uppercase tracking-wide"> <span>India:</span> <span>Hyderabad</span> <span>Chennai</span> <span>Bengaluru</span> <span>Gurugram</span> <span>Mumbai</span> </div>
<div class="border-t border-white/10 my-10"></div>

<div class="text-center text-white/40 text-[12px]">
© 2026 All Copyright Reserved by Marcamor.
</div>

</div>

</footer>