---
const cardslog = [
"/images/Vedantu.svg",
"/images/isha.svg",
"/images/tata1.svg",
"/images/tata2.svg",
"/images/tdp.svg",
"/images/KMLogo.svg",
"/images/ECL1.svg",
"/images/tsrtclogo.svg",
"/images/vsparkel.png",
"/images/Indian_National_Congress_hand_logo.svg"
];

const scrollLogos = [
"/images/EKAM.svg",
"/images/kankatala1.svg",
"/images/upGrad.svg",
"/images/ThinkRight.svg",
"/images/SUPERK.svg",
"/images/biggarden.svg",
"/images/garden.svg"
];
---

<section class="bg-black text-white py-[80px] overflow-hidden">

<div class="max-w-[90%] mx-auto">

<div class="flex flex-col xl:flex-row justify-between gap-12 lg:gap-16">

<div class="w-full lg:max-w-[420px]">

<button class="text-[14px] mb-4 font-medium text-white/50 bg-white/10 py-[6px] px-[12px] rounded-2xl">
Clients & Achievements
</button>

<div class="flex flex-col gap-[20px]">

<h2 class="font-semibold text-[26px] lg:text-[32px]">
Our Recent Clients
</h2>

</div>
</div>

<div class="w-full">

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-[10px]">

{cardslog.map((logo,index)=>(
<div
class="
h-[100px]
rounded-[6px]
bg-white/10
flex items-center justify-center
"
>

<img
src={logo}
alt=""
class="max-w-[100px] max-h-[100px] object-contain"
/>

</div>
))}

</div>

</div>

</div>


<div class="mt-[60px]">

<div class="relative overflow-hidden w-full h-auto">

<style>
.scroll-track{
display:flex;
align-items:center;
height:100%;
width:max-content;
animation:scrollLeft 20s linear infinite;
}

.scroll-container:hover .scroll-track{
animation-play-state:paused;
}

@keyframes scrollLeft{
0%{transform:translateX(0)}
100%{transform:translateX(-50%)}
}
</style>

<div class="scroll-container">

<div class="scroll-track gap-12 lg:gap-16">

{[...scrollLogos,...scrollLogos].map((logo)=>(
<img
src={logo}
alt=""
class="w-auto opacity-80 hover:opacity-100 transition duration-300"
/>
))}

</div>

</div>

<div class="absolute left-0 top-0 h-full w-12 lg:w-16 bg-gradient-to-r from-black to-transparent pointer-events-none"></div>

<div class="absolute right-0 top-0 h-full w-12 lg:w-16 bg-gradient-to-l from-black to-transparent pointer-events-none"></div>

</div>

</div>

</div>

</section>