---
const services = [
  "Search Engine Optimization",
  "Performance Marketing",
  "Social Media Marketing",
  "Content Marketing",
  "Email Marketing",
  "Affiliate Marketing",
  "Influencer Marketing",
  "YouTube Marketing",
  "WhatsApp Marketing",
];
---

<section class="bg-black text-white py-16 lg:py-24">

  <div class="max-w-[1440px] mx-auto w-[90%] flex flex-col items-center text-center gap-8">

    <!-- Top Label -->
    <span class="uppercase text-[13px] font-medium px-5 py-2 rounded-full bg-white/10 border border-white/20 backdrop-blur-md">
      Our Services
    </span>

    <!-- Heading -->
    <h1 class="text-[28px] sm:text-[36px] lg:text-[48px] font-semibold max-w-[820px] leading-tight">
      Strategic solutions built to drive <br /> growth, impact, and long-term success.
    </h1>

    <!-- Service Tags -->
    <div class="flex flex-wrap justify-center gap-3 max-w-[900px]">

      {services.map((service) => (
        <span class="text-[13px] px-4 py-2 rounded-full border border-white/20 bg-white/5 hover:bg-white/10 transition cursor-pointer">
          {service}
        </span>
      ))}

    </div>

  </div>

</section>