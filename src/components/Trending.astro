---
import { ChevronRight, Clock3, CalendarDays } from "lucide-react";

const cards = [
{
image:"/images/insights1.svg",
title:"Why Strong Brand Positioning Matters More Than Marketing Spend",
type:" Marketing",
date:" mar 07, 2025",
time:"4 MIN",
dec:"Many businesses believe growth comes from increasing marketing budgets. In reality, growth comes from clarity. When positioning, messaging, and audience alignment are defined correctly, marketing becomes far more effective and scalable."
}
];

const cards1 = [
{
image:"/images/insights2.svg",
title:"The Rise of Performance Driven Marketing in Modern Businesses",
type:" Marketing"
},
{
image:"/images/insights3.svg",
title:"Why Companies Are Investing More in Brand Strategy",
type:" Business"
},
{
image:"/images/insights4.svg",
title:"How AI Is Changing Digital Marketing Workflows",
type:" Technology"
},
{
image:"/images/insights9.svg",
title:"Why Customer Experience Is Becoming the Real Competitive Advantage",
type:" Business"
}
];

const posts = [
{
image: "/images/insights5.svg",
title: "Why Branding Is a Long Term Business Asset",
type: "Branding",
date: "Mar 07, 2025",
time: "15 min",
},
{
image: "/images/insights6.svg",
title: "Understanding the Difference Between Traffic and Revenue Growth",
type: "Marketing",
date: "Mar 07, 2025",
time: "20 min",
},
{
image: "/images/insights7.svg",
title: "How Digital Infrastructure Impacts Business Scalability",
type: "Business",
date: "Mar 07, 2025",
time: "30 min",
},
{
image: "/images/insights8.svg",
title: "Why Businesses Are Rebuilding Their Digital Platforms",
type: "Technology",
date: "Mar 07, 2025",
time: "40 min",
},
];
---

<section class="bg-black text-white mt-20 border-t border-white/10 border-b border-white/10">

<div class="max-w-[1440px] mx-auto w-[90%] py-[60px]">

<!-- HEADER -->
<div class="flex justify-between items-center mb-10 ">

<div class="relative">
<img src="/images/marcamore-logo.svg" class="w-[120px]" />
<img src="/images/insight-logo.svg" class="w-[90px] absolute top-[22px] left-[0]" />
</div>

<button class="h-[32px] px-4 rounded-full text-[10px] uppercase font-semibold bg-gradient-to-r from-[#EE5125] to-[#E51F31] flex items-center gap-2 text-white">
VISIT INSIGHTS
<ChevronRight size={14}/>
</button>

</div>
<div class="border-b border-white/10 mb-10"></div>
<div class="flex flex-col lg:flex-row gap-[60px]">

<!-- LEFT -->
<div class="lg:w-[65%]">

{cards.map((item)=>(

<div>

<div class="w-full h-[420px] rounded-[14px] overflow-hidden">
<img src={item.image} class="w-[745px] h-[450px] object-cover"/>
</div>

<div class="flex gap-2 mt-5">

<span class="bg-white/10 border border-white/10 px-3 py-1 rounded-full text-[10px] uppercase">{item.type}</span>

<span class="bg-white/10 border border-white/10 px-3 py-1 rounded-full text-[10px] flex items-center gap-1">
<Clock3 size={10}/>
{item.time}
</span>

<span class="bg-white/10 border border-white/10 px-3 py-1 rounded-full text-[10px] flex items-center gap-1">
<CalendarDays size={10}/>
{item.date}
</span>

</div>

<h2 class="text-[20px] font-semibold mt-4  leading-snug">
{item.title}
</h2>

<p class="text-white/60 text-[13px] mt-3 leading-[1.6] max-w-[90%]">
{item.dec}
</p>

</div>

))}

</div>

<!-- DIVIDER -->
<div class="hidden lg:block w-px bg-white/10"></div>

<!-- RIGHT -->
<div class="lg:w-[35%]">

<p class="text-[11px] text-white/30 mb-6 tracking-widest">
TRENDING
</p>

{cards1.map((ele)=>(

<div class="flex gap-4 pb-6 mb-6 border-b border-white/10 last:border-none last:mb-0">

<div class="w-[120px] h-[75px] rounded-md overflow-hidden flex-shrink-0">
<img src={ele.image} class="w-full h-full object-cover"/>
</div>

<div>

<span class="bg-white/10 border border-white/10 px-2 py-1 text-[10px] rounded-full font-semibold text-[9px] uppercase">
{ele.type}
</span>

<h4 class="text-[13px] font-medium mt-2 text-[10px] font-semibold leading-snug">
{ele.title}
</h4>

</div>

</div>

))}

</div>

</div>

</div>

</section>


<!-- BOTTOM -->
<section class="bg-black text-white border-t border-white/10">

<div class="max-w-[1440px] mx-auto w-[90%] py-[60px]">

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

{posts.map((post)=>(

<article class="space-y-4 cursor-pointer group">

<div class="w-full aspect-[16/10] rounded-[8px] overflow-hidden">
<img src={post.image} class="w-full h-full object-cover"/>
</div>

<div class="flex gap-2 flex-wrap text-[9px]">

<span class="bg-white/10 border border-white/10 px-2 py-1 rounded-full text-[10px] font-semibold uppercase">{post.type}</span>

<span class="bg-white/10 border border-white/10 px-2 py-1 text-[10px] font-semibold rounded-full flex items-center gap-1">
<Clock3 size={10}/>
{post.time}
</span>

<span class="bg-white/10 border border-white/10 px-2 py-1 rounded-full text-[10px] font-semibold flex items-center gap-1">
<CalendarDays size={10}/>
{post.date}
</span>

</div>

<h3 class="text-[13px] leading-snug group-hover:text-[#F05623] transition">
{post.title}
</h3>

</article>

))}

</div>

</div>

</section>