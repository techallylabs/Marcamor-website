---

const certifications = [
  "/images/certification1.svg",
  "/images/certification2.svg",
  "/images/certification3.svg"
];

const badges = [
  "/images/badge.svg",
  "/images/badge4.svg",
  "/images/badge5.svg",
  "/images/badge3.svg",
  "/images/badge1.svg",
  "/images/badge2.svg"
];

---

<section class="bg-black text-white py-10 lg:py-20 hidden">

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">

    <div class="flex flex-col items-center text-center gap-12">

      <!-- Label -->
      <div class="px-5 py-2 bg-white/10 rounded-full">
        <span class="text-[14px] font-medium tracking-wide">
          Awards & Certifications
        </span>
      </div>

      <!-- Heading -->
      <h2
        class="
        text-[34px]
        sm:text-[44px]
        lg:text-[64px]
        font-semibold
        leading-[1.1]
      "
      >
        Recognized Globally
      </h2>

      <!-- Certifications -->
      <div
        class="
        flex
        flex-col
        sm:flex-row
        flex-wrap
        justify-center
        items-center
        gap-10
      "
      >

        {certifications.map((img) => (
          <img
            src={img}
            alt="certification"
            class="
            w-[278px]
            h-[156px]
            object-contain
          "
          />
        ))}

      </div>

      <!-- Divider -->
      <div class="w-full border-t border-white/20 my-10"></div>

      <!-- Badges -->
      <div
        class="
        grid
        grid-cols-3
        lg:grid-cols-6
        gap-8
        justify-items-center
      "
      >

        {badges.map((img) => (
          <img
            src={img}
            alt="badge"
            class="
            w-[80px]
            sm:w-[90px]
            lg:w-[100px]
            h-auto
            object-contain
          "
          />
        ))}

      </div>

    </div>

  </div>

</section>