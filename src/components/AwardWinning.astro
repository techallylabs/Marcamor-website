---
import { ChevronRight } from "lucide-react";
---

<section class="relative bg-black text-white min-h-screen overflow-hidden">

  <!-- ✅ Background Video -->
  <video
    autoplay
    muted
    loop
    playsinline
    webkit-playsinline
    class="absolute inset-0 w-full h-full object-cover object-center"
  >
    <source src="/video/home-screen-bg-video.mp4" type="video/mp4" />
  </video>

  <!-- ✅ Gradient Overlay (BOTTOM DARK EFFECT) -->
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 via-40% to-transparent"></div>

  <!-- ✅ Content -->
  <div class="relative z-10 max-w-[1440px] mx-auto w-[90%] lg:pt-[160px] pt-[200px] pb-10">

    <div class="grid lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] gap-16 items-end lg:pb-20 xl:pb-0">

      <!-- LEFT -->
      <div class="flex flex-col gap-8 min-w-0">

        <h1 class="text-[32px] sm:text-[44px] lg:text-[54px] font-semibold leading-tight">
          Building Scalable <br />
          Brand Ecosystems
        </h1>

        <div class="flex flex-wrap gap-2 text-[12px] font-semibold text-white tracking-wide">
          <span class="bg-[#FFFFFF26] px-[12px] py-[6px] rounded-full backdrop-blur-2xl">Brand Strategy</span>
          <span class="bg-[#FFFFFF26] px-[12px] py-[6px] rounded-full backdrop-blur-2xl">Performance Marketing</span>
          <span class="bg-[#FFFFFF26] px-[12px] py-[6px] rounded-full backdrop-blur-2xl">SEO & Organic Growth</span>
          <span class="bg-[#FFFFFF26] px-[12px] py-[6px] rounded-full backdrop-blur-2xl">Web & App Development</span>
          <span class="bg-[#FFFFFF26] px-[12px] py-[6px] rounded-full backdrop-blur-2xl">Digital Consulting</span>
        </div>

        <div class="w-full max-w-[267px] h-px bg-white/25"></div>

        <!-- BUTTONS -->
        <div class="flex flex-wrap gap-3">

          <a href="#">
            <button class="group relative cursor-pointer h-[43px] uppercase min-w-[146px] px-6 rounded-full text-[12px] font-semibold bg-gradient-to-r from-[#EE5125] to-[#E51F31] flex items-center justify-center gap-2 text-white">
              <span class="relative">
                Explore all
                <span class="absolute left-0 -bottom-1 h-[1px] w-0 bg-white transition-all duration-300 group-hover:w-full"></span>
              </span>
              <ChevronRight size={16} />
            </button>
          </a>

        <a href="/requestproposal" class="cursor-pointer">
            <button class="group h-[42px] uppercase cursor-pointer px-6 rounded-full text-[12px] font-semibold border border-white/50 bg-[#FFFFFF26] backdrop-blur-2xl flex items-center justify-center gap-2 hover:bg-white/10 transition-all duration-300">
              <span class="relative">
                Schedule a Strategy Call
                <span class="absolute left-0 -bottom-1 h-[1px] w-0 bg-white transition-all duration-300 group-hover:w-full"></span>
              </span>
              <ChevronRight size={16} />
            </button>
          </a>

        </div>

        <p class="font-medium text-[14px] mt-2">
          8+ Years | Multi-Industry Expertise | Performance-Driven Systems | Scalable Operating Model
        </p>

      </div>

      <!-- RIGHT -->
      <div class="flex flex-col gap-4 max-w-[420px] lg:ml-auto text-center lg:text-left min-w-0">

        <h2 class="text-[16px] font-semibold border-b border-white/30 inline-block w-fit mx-auto lg:mx-0">
          Marcamor Consulting
        </h2>

        <p class="text-[14px] font-medium leading-relaxed">
          Marcamor is a growth-focused strategic organization integrating branding,
          digital marketing, technology, and consulting into one unified execution system.
        </p>

        <p class="text-[14px] font-medium leading-relaxed">
          We build scalable brand ecosystems designed for performance,
          expansion, and long-term enterprise value.
        </p>

      </div>

    </div>

  </div>

</section>