---
const stats = [
  { image: "/images/Simplification.svg", label: "1500+ Reviews" },
  { image: "/images/simp2.svg", label: "200+ Clients" },
  { image: "/images/simp3.svg", label: "8+ Years" },
];
---

<section class="bg-[#FFF9F6] text-black lg:pb-20 pb-10">
  <div class="max-w-[90%] mx-auto">
    <div class="flex justify-around flex-wrap items-center">

      {stats.map((item) => (
        <div class="flex flex-col items-center gap-4">
          <img
            src={item.image}
            alt={item.label}
            class="w-[80px] h-[80px] lg:w-[110px] lg:h-[110px]"
          />
          <p class="text-[16px] font-semibold">{item.label}</p>
        </div>
      ))}

    </div>
  </div>
</section>