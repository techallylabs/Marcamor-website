---
const { item } = Astro.props;
---

<div
class="
bg-[#0000000D]
w-full
text-black
rounded-[12px]
p-5
sm:p-6
border border-black/5
"
>

<div
class="flex justify-between items-start gap-4 cursor-pointer"
>

<div class="flex flex-col gap-3">

<h3 class="font-semibold text-[14px] sm:text-[15px] md:text-[16px] border-l-2 pl-3 border-black/20">
{item.title}
</h3>

<p class="text-[12px] sm:text-[13px] md:text-[14px] text-black/60">
{item.desc}
</p>

</div>

</div>

</div>